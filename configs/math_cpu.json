{
  "dataset_type": "math",
  "model_name": "meta-llama/Meta-Llama-3-8B-Instruct",
  "system_prompt": "You are a mathematics expert who solves problems clearly and accurately.",
  "domain_structure": {
    "topics": [
      "arithmetic",
      "algebra",
      "geometry",
      "trigonometry",
      "calculus",
      "linear algebra",
      "discrete mathematics",
      "probability",
      "statistics",
      "number theory",
      "optimization"
    ],
    "problem_types": [
      "proof",
      "step-by-step reasoning",
      "symbolic manipulation",
      "word problem",
      "derivation",
      "concept explanation"
    ],
    "difficulty_levels": [
      "elementary",
      "high school",
      "undergraduate",
      "advanced"
    ]
  },
  "dataset_structure": {
    "multi_turn": false,
    "include_reasoning": true
  },
  "generation": {
    "temperature": 0.45,
    "top_p": 0.9,
    "max_tokens": 240,
    "batch_size": 1,
    "max_parallel_requests": 1,
    "repetition_penalty": 1.12,
    "no_repeat_ngram_size": 4,
    "max_retries": 5,
    "template_only": false
  },
  "deduplication": {
    "similarity_threshold": 0.9
  }
}



